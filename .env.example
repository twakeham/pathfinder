# Environment Variables for Pathfinder LLM Playground
# Copy this file to .env and customize for your environment

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/pathfinder-dev

# Admin User Configuration (Optional - defaults provided)
ADMIN_EMAIL=admin@pathfinder.local
ADMIN_PASSWORD=PathfinderAdmin2025!

# Application Configuration (Future)
NODE_ENV=development
PORT=3000

# JWT Configuration (Future)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=24h

# OpenAI Configuration (Future)
OPENAI_API_KEY=your-openai-api-key-here

# Email Configuration (Future)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Redis Configuration (Future - for rate limiting)
REDIS_URL=redis://localhost:6379

# File Upload Configuration (Future)
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Security Configuration (Future)
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Development Configuration
DEBUG=false
LOG_LEVEL=info
